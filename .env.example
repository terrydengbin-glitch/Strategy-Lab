# Copy to ".env" in repo root and set DEEPSEEK_API_KEY.
# Example file is safe to commit; real ".env" is gitignored.

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
# Optional: enabled (default) / disabled. When enabled, uses API thinking + reasoning_effort.
# DEEPSEEK_THINKING=enabled
# DEEPSEEK_REASONING_EFFORT=max
# DEEPSEEK_TIMEOUT_SEC=300
